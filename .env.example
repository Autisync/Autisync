# ------------------------------------------------------------------------------
# Autisync Website - Environment Variables
# Copy this file to .env.local and fill in the values. Never commit .env.local.
# ------------------------------------------------------------------------------

# Contact Form - Microsoft Graph API (recommended for M365 tenants)
# Used by: src/app/api/contact/route.ts
#
# Works when SMTP AUTH is disabled tenant-wide.
# Setup summary:
# 1) Entra ID -> App registrations -> New registration (single tenant)
# 2) API permissions -> Microsoft Graph -> Application -> Mail.Send
# 3) Grant admin consent
# 4) Certificates & secrets -> New client secret -> copy VALUE (not ID)
# 5) Copy tenant ID and client ID from app overview

MICROSOFT_TENANT_ID=your-tenant-id
MICROSOFT_CLIENT_ID=your-app-client-id
MICROSOFT_CLIENT_SECRET=your-client-secret-value

# Internal lead email sender (must be a licensed mailbox)
OUTLOOK_FROM_EMAIL=noreply@autisync.com

# Confirmation sender to the submitting user (defaults to OUTLOOK_FROM_EMAIL)
OUTLOOK_NOREPLY_EMAIL=noreply@autisync.com

# Reply mailbox for customer confirmations
OUTLOOK_SUPPORT_EMAIL=support@austisync.com

# Recipient for internal lead notifications
OUTLOOK_TO_EMAIL=info@autisync.com

# Optional dedicated recipient for questionnaire submissions
OUTLOOK_QUESTIONNAIRE_TO_EMAIL=info@autisync.com

# Contact Form - SMTP fallback (non-Microsoft providers only)
# Used only if the Microsoft Graph vars above are missing.
# Note: usually does not work with M365 tenants where SMTP AUTH is disabled.

OUTLOOK_SMTP_HOST=smtp.office365.com
OUTLOOK_SMTP_PORT=587
OUTLOOK_SMTP_USER=your-smtp-username@autisync.com
OUTLOOK_SMTP_PASS=your-smtp-password

# Questionnaire Form (existing SMTP config)
# Used by: src/app/api/questionnaire/route.ts

SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username@autisync.com
SMTP_PASS=your-smtp-password

# Autisync CRM Backend (future - not active yet)
# AUTISYNC_CRM_ENABLED=false
# AUTISYNC_CRM_URL=https://api.autisync.com
# AUTISYNC_CRM_API_KEY=your-crm-api-key
